# Copia este ficheiro para .env e preenche os valores

# Base de dados
DATABASE_URL=postgresql://mobalance:mobalance@localhost:5432/mobalance

# JWT
SECRET_KEY=muda-esta-chave-para-algo-muito-secreto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin
ADMIN_EMAIL=admin@mobalance.pt

# Ambiente
ENVIRONMENT=development   # development | production

# CORS — origens do frontend em produção (separadas por vírgula)
# Exemplo Railway: https://mobalance-frontend.up.railway.app
# Exemplo Vercel:  https://mobalance.vercel.app
ALLOWED_ORIGINS=https://mobalance.vercel.app
